# ============================================================================
# NexusGate Secrets — EXAMPLE FILE
# Copy to secrets.yaml and fill in base64-encoded values, OR use:
#   kubectl create secret generic nexusgate-secrets \
#     --namespace nexusgate \
#     --from-literal=database-url='postgres://...' \
#     --from-literal=anthropic-api-key='sk-ant-...' \
#     --from-literal=openai-api-key='sk-...'
# ============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: nexusgate-secrets
  namespace: nexusgate
  labels:
    app.kubernetes.io/name: nexusgate
type: Opaque
stringData:
  # Cloud SQL connection string (private IP, no SSL needed within VPC)
  # Format: postgres://USER:PASSWORD@CLOUD_SQL_PRIVATE_IP:5432/nexusgate?sslmode=disable
  database-url: "postgres://nexusgate:CHANGE_ME@10.x.x.x:5432/nexusgate?sslmode=disable"

  # LLM API keys (at least one required for AI features)
  anthropic-api-key: "sk-ant-CHANGE_ME"
  openai-api-key: "sk-CHANGE_ME"
