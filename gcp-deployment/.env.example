# NexusGate GKE Deployment — Environment Configuration
# Copy to .env and fill in your values.
# These are used by the Makefile and deploy scripts.

# GCP project and region
GCP_PROJECT_ID=my-gcp-project-id
GCP_REGION=us-central1

# Path to the nexusgate source repo (for building images)
NEXUSGATE_SRC=../nexusgate

# Image tag (e.g., latest, v0.1.0, git-sha)
IMAGE_TAG=latest

# Cloud SQL private IP (from: cd terraform && terraform output cloud_sql_private_ip)
CLOUD_SQL_IP=

# Database credentials
DB_PASSWORD=
