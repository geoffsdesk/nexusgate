# NexusGate Environment Configuration
# Copy to .env and fill in your values

# LLM Providers (at least one required for AI features)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: Override default models
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o

# Database
DATABASE_URL=postgres://nexusgate:nexusgate@localhost:5432/nexusgate?sslmode=disable

# Service Ports
GATEWAY_PORT=8080
ORCHESTRATOR_PORT=8081
CONTRACT_ENGINE_PORT=8082
SECURITY_PORT=8083
